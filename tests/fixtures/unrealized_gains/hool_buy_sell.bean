; Minimal fixture for testing the unrealized_gains plugin.
;
; One unit of HOOL is bought on 2020-01-01 at cost 100 CHF and sold on
; 2021-01-01 at 166 CHF.  Monthly price directives sit on the 1st of each
; month so that end-of-month snapshots pick up the correct price via the
; most-recent-on-or-before semantics of get_price.
;
; Expected plugin behaviour:
;   - 12 unrealized entries (2020-01-31 through 2020-12-31) recording the
;     cumulative P&L delta each month.
;   - 1 clear entry (2021-01-31) reversing the December equity offset into
;     Income:Invest:IBKR:HOOL:PnL to net against the realized gain on sell.
;
; Can be loaded directly:
;   bean-check hool_buy_sell.bean
;   fava hool_buy_sell.bean

plugin "drnukebean.plugins.unrealized_gains" "Unrealized"

option "operating_currency" "CHF"

2020-01-01 commodity HOOL

; ---------------------------------------------------------------------------
; Accounts
; ---------------------------------------------------------------------------

2020-01-01 open Assets:Bank:CHF                 CHF
2020-01-01 open Assets:Invest:IBKR:HOOL         HOOL
2020-01-01 open Equity:Opening                  CHF
2020-01-01 open Income:Invest:IBKR:HOOL:PnL     CHF

; ---------------------------------------------------------------------------
; Opening balance
; ---------------------------------------------------------------------------

2020-01-01 * "Opening balance"
  Assets:Bank:CHF    100.00 CHF
  Equity:Opening    -100.00 CHF

; ---------------------------------------------------------------------------
; Buy trade
; ---------------------------------------------------------------------------

2020-01-01 * "Buy HOOL"
  Assets:Invest:IBKR:HOOL   1 HOOL {100.00 CHF}
  Assets:Bank:CHF          -100.00 CHF

; ---------------------------------------------------------------------------
; Monthly price directives (first of each month, Jan 2020 - Jan 2021)
; ---------------------------------------------------------------------------

2020-01-01 price HOOL  100.00 CHF
2020-02-01 price HOOL  101.00 CHF
2020-03-01 price HOOL  103.00 CHF
2020-04-01 price HOOL  106.00 CHF
2020-05-01 price HOOL  110.00 CHF
2020-06-01 price HOOL  115.00 CHF
2020-07-01 price HOOL  121.00 CHF
2020-08-01 price HOOL  128.00 CHF
2020-09-01 price HOOL  136.00 CHF
2020-10-01 price HOOL  145.00 CHF
2020-11-01 price HOOL  155.00 CHF
2020-12-01 price HOOL  166.00 CHF

2020-12-15 * "Sell HOOL"
  Assets:Invest:IBKR:HOOL           -1 HOOL {100.00 CHF} @ 166.00 CHF
  Assets:Bank:CHF                  166.00 CHF
  Income:Invest:IBKR:HOOL:PnL      -66.00 CHF

; 2021-01-01 price HOOL  178.00 CHF
; 2021-02-01 price HOOL  191.00 CHF
; 2021-03-01 price HOOL  205.00 CHF
; 2021-04-01 price HOOL  220.00 CHF
; 2021-05-01 price HOOL  236.00 CHF
; 2021-06-01 price HOOL  253.00 CHF
; 2021-07-01 price HOOL  271.00 CHF
; 2021-08-01 price HOOL  290.00 CHF
; 2021-09-01 price HOOL  310.00 CHF
; 2021-10-01 price HOOL  331.00 CHF
; 2021-11-01 price HOOL  353.00 CHF
; 2021-12-01 price HOOL  376.00 CHF

; ; ---------------------------------------------------------------------------
; ; Sell trade
; ; ---------------------------------------------------------------------------

; 2021-12-01 * "Sell HOOL"
;   Assets:Invest:IBKR:HOOL           -1 HOOL {100.00 CHF} @ 376.00 CHF
;   Assets:Bank:CHF                  376 CHF
;   Income:Invest:IBKR:HOOL:PnL      -276.00 CHF


2022-12-01 price HOOL  376.00 CHF